<!DOCTYPE html>
<html>
<head>
  <style>
    body {
      font-family: Segoe UI;
      text-align: center;
      background-color: #f3f2f1;
      margin: 0;
      padding: 20px;
    }
    .title {
      font-size: 20px;
      color: #323130;
    }
    .countdown {
      font-size: 28px;
      font-weight: bold;
      color: #d83b01;
      margin-top: 10px;
    }
  </style>
</head>
<body>

<div class="title">Performance Reviews close in:</div>
<div id="countdown" class="countdown"></div>

<script>
var countDownDate = new Date("Jul 19, 2026 17:00:00").getTime();

setInterval(function() {
  var now = new Date().getTime();
  var distance = countDownDate - now;

  var days = Math.floor(distance / (1000 * 60 * 60 * 24));

  document.getElementById("countdown").innerHTML =
    days + " days remaining";

}, 1000);
</script>

</body>
</html>
